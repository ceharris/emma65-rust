{
  "productName": "emma65-debugger",
  "version": "0.1.0",
  "identifier": "org.emma65.debugger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "emma65 Debugger",
        "width": 1600,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "terminal",
        "title": "emma65 Terminal",
        "url": "terminal.html",
        "width": 720,
        "height": 460,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
